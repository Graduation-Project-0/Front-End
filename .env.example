# Backend API root (must include /api/v1, no trailing slash). Copy to .env and adjust.
#
# Local dev (recommended): leave unset so the app uses `/api/v1` and Vite proxies to Laravel
# (see vite.config.js) — avoids CORS when the UI is on localhost:5173 and the API is on :8000.
#
# If you set a full URL here, the browser calls that origin directly; your API must send proper
# CORS headers (and allow credentials if you set withCredentials in axios).
# VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
